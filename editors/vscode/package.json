{
  "name": "erbfmt-vscode",
  "displayName": "erbfmt",
  "description": "Format, lint, highlight, and comment ERB and HTML+ERB templates with erbfmt.",
  "version": "0.1.5",
  "publisher": "erbfmt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hinamimi/erbfmt.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/hinamimi/erbfmt/issues"
  },
  "homepage": "https://hinamimi.github.io/erbfmt/",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Syntax highlighting is available, but formatting and diagnostics execute the configured erbfmt command."
    },
    "virtualWorkspaces": false
  },
  "categories": [
    "Formatters",
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "erb",
    "html-erb",
    "formatter",
    "linter",
    "ruby",
    "rails"
  ],
  "galleryBanner": {
    "color": "#1f2937",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:erb",
    "onLanguage:html-erb",
    "onCommand:erbfmt.formatDocument",
    "onCommand:erbfmt.lintDocument",
    "onCommand:erbfmt.showCommand",
    "onCommand:erbfmt.toggleComment"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "html-erb",
        "aliases": [
          "HTML ERB",
          "html.erb"
        ],
        "filenamePatterns": [
          "*.html.erb"
        ],
        "mimetypes": [
          "text/html+erb"
        ]
      }
    ],
    "grammars": [
      {
        "language": "html-erb",
        "scopeName": "text.html.erb",
        "path": "./syntaxes/html-erb.tmLanguage.json",
        "embeddedLanguages": {
          "source.ruby": "ruby",
          "text.html.basic": "html"
        }
      }
    ],
    "commands": [
      {
        "command": "erbfmt.formatDocument",
        "title": "erbfmt: Format Document"
      },
      {
        "command": "erbfmt.lintDocument",
        "title": "erbfmt: Lint Document"
      },
      {
        "command": "erbfmt.showCommand",
        "title": "erbfmt: Show Command"
      },
      {
        "command": "erbfmt.toggleComment",
        "title": "erbfmt: Toggle Comment"
      }
    ],
    "keybindings": [
      {
        "command": "erbfmt.toggleComment",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "editorTextFocus && !editorReadonly && editorLangId == 'html-erb'"
      },
      {
        "command": "erbfmt.toggleComment",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "editorTextFocus && !editorReadonly && editorLangId == erb"
      }
    ],
    "configuration": {
      "title": "erbfmt",
      "properties": {
        "erbfmt.command": {
          "type": "string",
          "default": "erbfmt",
          "description": "Command used to run erbfmt. This may include leading arguments, such as `bundle exec erbfmt`, or an absolute binary path for pinned local setups."
        },
        "erbfmt.arguments": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments inserted after erbfmt.command and before erbfmt's own formatter arguments."
        },
        "erbfmt.configPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to erbfmt.json. Relative paths are resolved from the workspace folder."
        },
        "erbfmt.lint.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable erbfmt diagnostics by running erbfmt --lint on open and save."
        },
        "erbfmt.formatDiagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Warn when the active ERB document differs from erbfmt's formatted output."
        }
      }
    },
    "configurationDefaults": {
      "[erb]": {
        "editor.defaultFormatter": "erbfmt.erbfmt-vscode"
      },
      "[html-erb]": {
        "editor.defaultFormatter": "erbfmt.erbfmt-vscode"
      }
    }
  },
  "scripts": {
    "check": "biome check .",
    "compile": "tsc -p .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "package": "vsce package --no-dependencies",
    "test": "npm run check && npm run compile && node test/smoke.test.js && node test/comment.test.js && node test/command.test.js",
    "test:host": "npm run compile && cargo build --manifest-path ../../Cargo.toml && node test/runTest.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "mocha": "^11.7.6",
    "typescript": "^6.0.0"
  }
}
