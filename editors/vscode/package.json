{
  "name": "erbfmt-vscode",
  "displayName": "erbfmt",
  "description": "VSCode formatter wrapper for erbfmt.",
  "version": "0.1.0",
  "publisher": "erbfmt",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:erb",
    "onLanguage:html-erb",
    "onCommand:erbfmt.formatDocument",
    "onCommand:erbfmt.lintDocument"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "html-erb",
        "aliases": [
          "HTML ERB",
          "html.erb"
        ],
        "filenamePatterns": [
          "*.html.erb"
        ],
        "mimetypes": [
          "text/html+erb"
        ]
      }
    ],
    "commands": [
      {
        "command": "erbfmt.formatDocument",
        "title": "erbfmt: Format Document"
      },
      {
        "command": "erbfmt.lintDocument",
        "title": "erbfmt: Lint Document"
      }
    ],
    "configuration": {
      "title": "erbfmt",
      "properties": {
        "erbfmt.command": {
          "type": "string",
          "default": "erbfmt",
          "description": "Command used to run the erbfmt binary."
        },
        "erbfmt.arguments": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Arguments inserted before erbfmt's own formatter arguments. Use this for local development, for example [\"run\", \"--quiet\", \"--\"]."
        },
        "erbfmt.configPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to erbfmt.json. Relative paths are resolved from the workspace folder."
        },
        "erbfmt.lint.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable erbfmt diagnostics by running erbfmt --lint on open and save."
        }
      }
    },
    "configurationDefaults": {
      "[erb]": {
        "editor.defaultFormatter": "erbfmt.erbfmt-vscode"
      },
      "[html-erb]": {
        "editor.defaultFormatter": "erbfmt.erbfmt-vscode"
      }
    }
  },
  "scripts": {
    "check": "biome check .",
    "compile": "tsc -p .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "package": "vsce package --no-dependencies",
    "test": "npm run check && npm run compile && node test/smoke.test.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^6.0.0"
  }
}
