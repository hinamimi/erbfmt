{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo fmt",
      "type": "shell",
      "command": "cargo",
      "args": ["fmt"],
      "problemMatcher": []
    },
    {
      "label": "cargo check --all-targets",
      "type": "shell",
      "command": "cargo",
      "args": ["check", "--all-targets"],
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo clippy",
      "type": "shell",
      "command": "cargo",
      "args": ["clippy"],
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo test",
      "type": "shell",
      "command": "cargo",
      "args": ["test"],
      "group": "test",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo run sample",
      "type": "shell",
      "command": "cargo",
      "args": ["run", "--", "samples/sample.html.erb"],
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo run write sample",
      "type": "shell",
      "command": "cargo",
      "args": ["run", "--", "--write", "samples/sample.html.erb"],
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo run lint sample",
      "type": "shell",
      "command": "cargo",
      "args": ["run", "--", "--lint", "samples/sample.html.erb"],
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo run lint next sample",
      "type": "shell",
      "command": "cargo",
      "args": ["run", "--", "--lint", "samples/lint-next.html.erb"],
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo run lint samples",
      "type": "shell",
      "command": "cargo",
      "args": [
        "run",
        "--",
        "--lint",
        "samples/sample.html.erb",
        "samples/lint-next.html.erb"
      ],
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo run check sample",
      "type": "shell",
      "command": "cargo",
      "args": ["run", "--", "--check", "samples/sample.html.erb"],
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "erbfmt: verify",
      "dependsOrder": "sequence",
      "dependsOn": [
        "cargo fmt",
        "cargo check --all-targets",
        "cargo clippy",
        "cargo test",
        "cargo run sample",
        "cargo run lint sample"
      ],
      "problemMatcher": []
    }
  ]
}
