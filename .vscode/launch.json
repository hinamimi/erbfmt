{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run erbfmt VSCode Extension",
      "type": "extensionHost",
      "request": "launch",
      "preLaunchTask": "vscode extension compile",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/editors/vscode",
        "${workspaceFolder}"
      ]
    }
  ]
}
