<section class="lint-next">
  <!--
    This file intentionally contains remaining lint issues.
    Supported branches should format normally and no longer lint.
  -->

  <h1>Future lint examples</h1>

  <% %>
  <%= %>

  <% if show_empty_state %>
  <% end %>

  <% if current_user %>
    <p>Welcome, <%= current_user.name %></p>
    <% else %>
    <p>Please sign in</p>
  <% end %>

  <% case current_user&.role %>
    <% when "admin" %>
    <p>Admin tools</p>
    <% when "member" %>
    <p>Member dashboard</p>
  <% end %>

  <% while job.running? %>
  <p>Waiting for the job to finish...</p>
</section>
