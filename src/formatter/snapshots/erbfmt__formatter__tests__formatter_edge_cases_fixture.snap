---
source: src/formatter/tests.rs
expression: format_source(formatter_edge_cases_fixture())
---
<%
message = <<TEXT
hello
TEXT
%>

<article
  class="edge-card"
  data-controller="edge-preview"
  data-edge-preview-user-id-value="<%= user.id %>"
>
  <!-- before control flow -->
  <% if user.present? %>
    <p>Hello, <%= user.display_name %>. Your plan is <%= user.plan_name %>.</p>
    <a
      href="/users/<%= user.id %>"
      aria-label="<%= user.display_name %>"
    >
      Open profile
    </a>
    <%=
      link_to(
        "Edit profile",
        edit_user_path(user),
        class: "button button--primary"
      )
    %>
    <button
      class="button <%= 'button--hidden' if hidden? %>"
      id=<%= button_id %>
      type="button"
    >Save</button>
    <details
      <%= "open" unless request.user_agent&.match?(/Mobile|Android|iPhone|iPad/) %>
      class="edge-details"
    >
      <summary>Filters</summary>
    </details>
    <ul>
      <li class=""><%= link_to "home", root_path, class: "" %></li>
    </ul>
    <pre>  A <%=   value   %> B  </pre>
    <script>const value = "<%=   value   %>";</script>
    <template><span><%=   value   %></span></template>
    <%
      # Keep this block raw enough that comments and control flow do not collapse.
      value = params[:value]
      if value.present?
        track(value)
      end
    %>
  <% else %>
    <!-- empty state -->
    <p>Please sign in.</p>
  <% end %>
</article>
