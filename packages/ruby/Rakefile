# frozen_string_literal: true

require "fileutils"
require "open3"
require "rake/testtask"
require "rbconfig"
require "rubygems/package"
require "tmpdir"
require_relative "lib/erbfmt/version"

PACKAGE_ROOT = __dir__
REPOSITORY_ROOT = File.expand_path("../..", PACKAGE_ROOT)
VERSION_SCRIPT = File.join(REPOSITORY_ROOT, "scripts/version.rb")

def gem_platform
  configured = ENV["ERBFMT_PACKAGE_PLATFORM"]
  return configured unless configured.nil? || configured.empty?

  local = Gem::Platform.local.to_s
  local == "x86_64-linux" ? "x86_64-linux-gnu" : local
end

def ruby_platform?(platform)
  Gem::Platform.new(platform) == Gem::Platform::RUBY
end

def packaged_binary_name(platform)
  platform.include?("mingw") || platform.include?("mswin") ? "erbfmt-bin.exe" : "erbfmt-bin"
end

def staged_binaries
  Dir[File.join(PACKAGE_ROOT, "libexec", "erbfmt-bin*")]
end

def gem_package_path(platform = gem_platform)
  package = if ruby_platform?(platform)
              "erbfmt-#{Erbfmt::VERSION}.gem"
            else
              "erbfmt-#{Erbfmt::VERSION}-#{platform}.gem"
            end
  File.join(PACKAGE_ROOT, "pkg", package)
end

def cargo_version
  cargo_toml = File.read(File.join(REPOSITORY_ROOT, "Cargo.toml"))
  match = cargo_toml.match(/^version = "([^"]+)"$/)
  abort "Cargo.toml package version not found" unless match

  match[1]
end

def gem_command
  File.join(RbConfig::CONFIG.fetch("bindir"), Gem.win_platform? ? "gem.cmd" : "gem")
end

def with_unbundled_env(&block)
  return Bundler.with_unbundled_env(&block) if defined?(Bundler)

  yield
end

Rake::TestTask.new(:test) do |task|
  task.libs << File.join(PACKAGE_ROOT, "lib")
  task.pattern = File.join(PACKAGE_ROOT, "test/**/*_test.rb")
  task.warning = true
end

task default: :test

desc "Verify Cargo, Ruby gem, and VSCode versions correspond"
task :verify_version do
  sh Gem.ruby, VERSION_SCRIPT, "verify"
end

namespace :gem do
  desc "Build a Ruby gem package"
  task build: [:test, :verify_version] do
    source = ENV["ERBFMT_BINARY"]
    platform = gem_platform
    package = gem_package_path(platform)
    staged = nil
    FileUtils.rm_f(staged_binaries)

    unless ruby_platform?(platform)
      abort "ERBFMT_BINARY must point to a built erbfmt binary" if source.nil? || source.empty?

      source = File.expand_path(source, REPOSITORY_ROOT)
      abort "ERBFMT_BINARY is missing or not executable: #{source}" unless File.file?(source) && File.executable?(source)

      staged = File.join(PACKAGE_ROOT, "libexec", packaged_binary_name(platform))
      FileUtils.mkdir_p(File.dirname(staged))
      FileUtils.cp(source, staged)
      FileUtils.chmod(0o755, staged)
    end

    FileUtils.mkdir_p(File.dirname(package))

    with_unbundled_env do
      Dir.chdir(PACKAGE_ROOT) do
        sh(
          { "ERBFMT_GEM_PLATFORM" => platform },
          gem_command,
          "build",
          "erbfmt.gemspec",
          "--output",
          package
        )
      end
    end
  ensure
    FileUtils.rm_f(staged) if staged
  end

  desc "Build and inspect the Ruby gem package"
  task verify_package: :build do
    package = gem_package_path
    platform = gem_platform
    packaged_binary = File.join("libexec", packaged_binary_name(platform))
    specification = Gem::Package.new(package).spec

    abort "unexpected gem platform: #{specification.platform}" unless specification.platform.to_s == platform
    abort "unexpected gem version: #{specification.version}" unless specification.version.to_s == Erbfmt::VERSION
    if ruby_platform?(platform)
      binary_files = specification.files.grep(%r{\Alibexec/erbfmt-bin})
      abort "ruby fallback gem must not package a binary: #{binary_files.join(", ")}" unless binary_files.empty?
    else
      abort "packaged binary is missing: #{packaged_binary}" unless specification.files.include?(packaged_binary)
    end
    abort "gemspec is missing from package files" unless specification.files.include?("erbfmt.gemspec")

    Dir.mktmpdir("erbfmt-gem-unpack") do |directory|
      with_unbundled_env do
        sh(gem_command, "unpack", package, "--target", directory)
      end

      unpacked_directory = if ruby_platform?(platform)
                             "erbfmt-#{Erbfmt::VERSION}"
                           else
                             "erbfmt-#{Erbfmt::VERSION}-#{platform}"
                           end
      unpacked_gemspec = File.join(directory, unpacked_directory, "erbfmt.gemspec")
      abort "unpacked gemspec is missing: #{unpacked_gemspec}" unless File.file?(unpacked_gemspec)

      unpacked_specification = begin
        previous_verbose = $VERBOSE
        $VERBOSE = nil
        Gem::Specification.load(unpacked_gemspec)
      ensure
        $VERBOSE = previous_verbose
      end
      abort "unpacked gemspec could not be loaded: #{unpacked_gemspec}" if unpacked_specification.nil?
      abort "unexpected unpacked gem platform: #{unpacked_specification.platform}" unless unpacked_specification.platform.to_s == platform
      abort "unexpected unpacked gem version: #{unpacked_specification.version}" unless unpacked_specification.version.to_s == Erbfmt::VERSION
    end
  end

  desc "Build, install, and execute the Ruby gem package in isolation"
  task verify: :verify_package do
    package = gem_package_path
    platform = gem_platform
    source = ENV["ERBFMT_BINARY"]
    if ruby_platform?(platform)
      abort "ERBFMT_BINARY must point to a built erbfmt binary to verify the ruby fallback gem" if source.nil? || source.empty?

      source = File.expand_path(source, REPOSITORY_ROOT)
      abort "ERBFMT_BINARY is missing or not executable: #{source}" unless File.file?(source) && File.executable?(source)
    end

    Dir.mktmpdir("erbfmt-gem") do |directory|
      gem_home = File.join(directory, "gems")
      bindir = File.join(directory, "bin")

      with_unbundled_env do
        sh(
          gem_command,
          "install",
          "--local",
          "--no-document",
          "--install-dir",
          gem_home,
          "--bindir",
          bindir,
          package
        )
      end

      executable = File.join(bindir, Gem.win_platform? ? "erbfmt.bat" : "erbfmt")
      execution_environment = {
        "ERBFMT_BINARY" => ruby_platform?(platform) ? source : nil,
        "GEM_HOME" => gem_home,
        "GEM_PATH" => gem_home
      }
      if Gem::Version.new(Erbfmt::VERSION).prerelease?
        execution_environment["GEM_REQUIREMENT_ERBFMT"] = ">= 0.a"
      end

      stdout, stderr, status = with_unbundled_env do
        Open3.capture3(
          execution_environment,
          executable,
          "--version"
        )
      end

      abort stderr unless status.success?
      expected = "erbfmt #{cargo_version}"
      abort "unexpected version output: #{stdout.inspect}" unless stdout.strip == expected
    end
  end
end
